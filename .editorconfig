root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true
max_line_length = 140

[*.{kt,kts}]
ktlint_standard_filename = disabled
ktlint_function_naming_ignore_when_annotated_with = Composable, Preview, Test
ktlint_standard_no-wildcard-imports = enabled
ktlint_standard_trailing-comma-on-call-site = enabled
ktlint_standard_trailing-comma-on-declaration-site = enabled

[*.{xml,yml,yaml,json,toml}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

<?xml version="1.0" encoding="utf-8"?>
<!-- Legacy (pre-Android 12) auto-backup policy. allowBackup="false" in the manifest is
     authoritative; this file exists so the manifest reference resolves cleanly. -->
<full-backup-content>
    <exclude domain="root" />
    <exclude domain="database" />
    <exclude domain="sharedpref" />
    <exclude domain="file" />
</full-backup-content>
